# Copy this file to `.env` and adjust if needed.
# `.env` is gitignored (never commit real config/secrets); this template is committed.
#
# Node 20.6+ loads .env automatically when started with `--env-file`, but for
# simplicity our code reads these via process.env (see src/llm.ts). tsx also
# supports --env-file if we want automatic loading later.

# --- LLM gateway (OpenAI-compatible) ---
# The local gateway needs no API key and works in China. Endpoint + model are
# configurable here so we can later swap in the real OpenAI/Anthropic API
# without touching code.
LLM_BASE_URL=http://localhost:4399/v1
LLM_MODEL=gpt-4o-2024-11-20

# If a future endpoint requires auth, put the key here (left blank for the
# local gateway which ignores it).
LLM_API_KEY=
